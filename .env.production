# SECURITY NOTICE: This file was sanitized — PII and domain-identifying values
# were removed from git history.
#
# Do NOT add real secrets, names, ABNs, or API keys here.
# Set all production values as secrets/env vars in your hosting platform (Vercel, etc.).
#
# ACTION REQUIRED (run locally on the main branch):
#   git filter-repo --path .env.production --invert-paths
# This purges the previous committed version from git history.
#
# See .env.local (gitignored) for development values.

# Application
NEXT_PUBLIC_APP_NAME="Nexus Agent Dashboard"
NEXT_PUBLIC_ENVIRONMENT=production

# API Configuration — set real values in hosting platform secrets, not here
# NEXT_PUBLIC_APP_URL=https://your-domain.com.au
# NEXT_PUBLIC_API_URL=https://api.your-domain.com.au
# NEXT_PUBLIC_WS_URL=wss://api.your-domain.com.au
# NEXT_PUBLIC_DOMAIN=your-domain.com.au

# API Timeouts
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_WS_RECONNECT_DELAY=5000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEVTOOLS=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=true

# Analytics (Optional — set in platform secrets)
# NEXT_PUBLIC_GA_ID=your-ga-id
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key

# Monitoring (Optional — set in platform secrets)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
